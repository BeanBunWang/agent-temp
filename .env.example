# Copy this file to .env locally if you want, but do not commit real secrets.

# Generic OpenAI-compatible provider.
AGENT_MODEL_BASE_URL=https://api.openai.com/v1
AGENT_MODEL_API_KEY=replace-with-your-key
AGENT_MODEL_NAME=gpt-4.1-mini

# DeepSeek provider. Keep the real key in your shell, 1Password, direnv, or CI secrets.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMELINE_MODEL=deepseek-v4-flash
